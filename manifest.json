{
  "manifest_version": 3,
  "name": "Purdue RMP — Inline Professor Ratings",
  "version": "1.1.0",
  "description": "Overlays RateMyProfessors ratings inline on Purdue's UniTime scheduling site, so students can compare professors without leaving the page.",
  "permissions": [
    "storage",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rmp_headers",
        "enabled": true,
        "path": "rules/rmp_headers.json"
      }
    ]
  },
  "host_permissions": [
    "https://timetable.mypurdue.purdue.edu/*",
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://timetable.mypurdue.purdue.edu/*"],
      "js": ["src/content/index.js"],
      "type": "module",
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/options/index.html"
}
